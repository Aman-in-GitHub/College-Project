{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:generate": "bun x --bun @better-auth/cli@latest generate --output ./src/db/schema/auth.ts",
    "db:generate": "bun x --bun drizzle-kit generate",
    "db:migrate": "bun x --bun drizzle-kit migrate",
    "db:reset": "bun src/db/reset.ts",
    "db:seed": "bun src/db/seed.ts",
    "db:studio": "bun x --bun drizzle-kit studio",
    "dev": "bun db:migrate && bun db:seed && bun db:studio & bun run --hot src/index.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "ai": "^6.0.168",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "hono-rate-limiter": "^0.5.3",
    "nanoid": "^5.1.9",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  }
}
